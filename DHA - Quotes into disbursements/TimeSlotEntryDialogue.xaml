<Window x:Class="DHA.DSTC.WPF.TimeSlotEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Time for Time Slot" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Inherit styles from parent window -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Log Time for Time Slot" FontSize="18" FontWeight="Bold" 
                      Foreground="#1E293B" Margin="0,0,0,8"/>
            <TextBlock x:Name="TimeSlotLabel" Text="Time Slot: 09:00 - 09:15 (15 minutes)" 
                      FontSize="14" Foreground="#64748B"/>
        </StackPanel>

        <!-- Existing Time Info -->
        <Border x:Name="ExistingTimePanel" Grid.Row="1" Background="#FEF3C7" 
               BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="6" 
               Padding="12" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock x:Name="ExistingTimeText" Text="Already logged: 0.25 hours" 
                          FontWeight="SemiBold" Foreground="#92400E" Margin="0,0,0,8"/>
                <TextBlock x:Name="ExistingEntriesText" FontSize="11" Foreground="#78350F"
                          TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Main Form -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Project Selection -->
                <TextBlock Text="Project" Style="{StaticResource FormLabelStyle}"/>
                <ComboBox x:Name="ProjectComboBox" Margin="0,0,0,16" Height="32"
                         DisplayMemberPath="Name" SelectedValuePath="Id"
                         SelectionChanged="ProjectComboBox_SelectionChanged"/>

                <!-- Quick Time Buttons -->
                <TextBlock Text="Quick Time Selection" Style="{StaticResource FormLabelStyle}"/>
                <WrapPanel x:Name="QuickTimePanel" Orientation="Horizontal" Margin="0,0,0,16">
                    <!-- Buttons will be added programmatically -->
                </WrapPanel>

                <!-- Time Input -->
                <TextBlock Text="Time to Log" Style="{StaticResource FormLabelStyle}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Hours" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBox x:Name="HoursTextBox" TextAlignment="Center" MaxLength="2" 
                                Height="32" Text="0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Bottom" 
                              Margin="12,0,12,8" FontSize="16" FontWeight="Bold"/>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Minutes" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBox x:Name="MinutesTextBox" TextAlignment="Center" MaxLength="2" 
                                Height="32" Text="15" TextChanged="MinutesTextBox_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="16,0,0,0" VerticalAlignment="Bottom">
                        <TextBlock Text="= 0.25h" FontSize="11" Foreground="#64748B" 
                                  x:Name="TotalHoursLabel"/>
                    </StackPanel>
                </Grid>

                <!-- Category Selection -->
                <TextBlock Text="Category" Style="{StaticResource FormLabelStyle}"/>
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton x:Name="ChargeableRadioButton" Content="Chargeable" 
                               IsChecked="True" Margin="0,0,20,0" GroupName="TimeCategory"/>
                    <RadioButton x:Name="NonChargeableRadioButton" Content="Non-Chargeable" 
                               Margin="0,0,20,0" GroupName="TimeCategory"/>
                    <RadioButton x:Name="SpeculativeRadioButton" Content="Speculative" 
                               Margin="0,0,20,0" GroupName="TimeCategory"/>
                </WrapPanel>

                <!-- Comments -->
                <TextBlock Text="Comments" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="CommentsTextBox" Height="60" TextWrapping="Wrap" 
                        AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                        Margin="0,0,0,16"/>

                <!-- Tips -->
                <Border Background="#F0F9FF" BorderBrush="#0EA5E9" BorderThickness="1" 
                       CornerRadius="6" Padding="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="?? Tips for Time Slot Logging:" FontWeight="SemiBold" 
                                  Foreground="#0C4A6E" Margin="0,0,0,8"/>
                        <TextBlock Foreground="#075985" TextWrapping="Wrap" FontSize="11" LineHeight="16">
                             Each slot represents 15 minutes of your day<LineBreak/>
                             You can log more than 15 minutes per slot if needed<LineBreak/>
                             Use Ctrl+Enter to save quickly, Escape to cancel<LineBreak/>
                             Comments help track what you worked on during this time
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Keyboard shortcuts info -->
            <TextBlock Grid.Column="0" Text="Ctrl+Enter to save, Escape to cancel" 
                      FontSize="11" Foreground="#64748B" VerticalAlignment="Center"/>

            <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" 
                   Margin="0,0,12,0" MinWidth="80" Click="CancelButton_Click"/>

            <Button Grid.Column="2" Content="Save Time Entry" Style="{StaticResource PrimaryButtonStyle}" 
                   MinWidth="120" Click="SaveButton_Click"/>
        </Grid>
    </Grid>
</Window>