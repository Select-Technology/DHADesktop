<Window x:Class="DHA.DSTC.WPF.EditDisbursementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Disbursement" Height="650" Width="450"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitleLabel" Text="Edit Disbursement" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Classification Selection (only show for new disbursements) -->
            <TextBlock x:Name="ClassificationLabel" Text="Disbursement For" Margin="0,0,0,5" Visibility="Collapsed"/>
            <StackPanel x:Name="ClassificationPanel" Orientation="Horizontal" Margin="0,0,0,15" Visibility="Collapsed">
                <RadioButton x:Name="ProjectRadio" Content="Project" IsChecked="True" 
                           GroupName="Classification" Margin="0,0,20,0" 
                           Checked="ClassificationRadio_Checked"/>
                <RadioButton x:Name="QuoteRadio" Content="Quote" 
                           GroupName="Classification" 
                           Checked="ClassificationRadio_Checked"/>
            </StackPanel>

            <!-- Date -->
            <TextBlock Text="Date" Margin="0,0,0,5"/>
            <DatePicker x:Name="DatePicker" Margin="0,0,0,15" SelectedDate="{x:Static sys:DateTime.Today}"/>

            <!-- Project Selection -->
            <TextBlock x:Name="ProjectLabel" Text="Project" Margin="0,0,0,5"/>
            <ComboBox x:Name="ProjectComboBox" Margin="0,0,0,15" DisplayMemberPath="Name"/>

            <!-- Quote Selection (hidden by default) -->
            <TextBlock x:Name="QuoteLabel" Text="Quote" Margin="0,0,0,5" Visibility="Collapsed"/>
            <ComboBox x:Name="QuoteComboBox" Margin="0,0,0,15" DisplayMemberPath="Name" Visibility="Collapsed"/>

            <!-- Disbursement Type -->
            <TextBlock Text="Disbursement Type" Margin="0,0,0,5"/>
            <ComboBox x:Name="DisbursementTypeComboBox" Margin="0,0,0,15" DisplayMemberPath="Name"
                     SelectionChanged="DisbursementTypeComboBox_SelectionChanged"/>

            <!-- Amount (for non-unit based) -->
            <TextBlock x:Name="AmountLabel" Text="Amount" Margin="0,0,0,5"/>
            <Grid x:Name="AmountPanel" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#163;" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                <TextBox x:Name="AmountTextBox" Grid.Column="1"/>
            </Grid>

            <!-- Units (for unit-based disbursements) -->
            <TextBlock x:Name="UnitsLabel" Text="Units" Margin="0,0,0,5" Visibility="Collapsed"/>
            <Grid x:Name="UnitsPanel" Margin="0,0,0,15" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UnitsTextBox" Grid.Column="0" TextChanged="UnitsTextBox_TextChanged"/>
                <TextBlock x:Name="UnitChargeLabel" Grid.Column="1" Text="&#215; &#163;0.00" VerticalAlignment="Center" Margin="8,0"/>
                <TextBlock x:Name="CalculatedAmountLabel" Grid.Column="2" Text="= &#163;0.00" VerticalAlignment="Center" Margin="8,0" FontWeight="Bold"/>
            </Grid>

            <!-- Description -->
            <TextBlock Text="Description" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>

            <!-- Billable to Client -->
            <CheckBox x:Name="BillableCheckBox" Content="Billable to Client" IsChecked="True"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="Save" Width="80" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>