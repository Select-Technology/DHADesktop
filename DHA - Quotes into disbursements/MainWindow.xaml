<Window x:Class="DHA.DSTC.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        mc:Ignorable="d"
        Title="DHA Time Management" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/app.ico"
        Background="{DynamicResource BackgroundBrush}">


    <Window.Resources>
        <!-- Modern Color Palette -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>

        <!-- Modern Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Button Style for Project/Quote Selection -->
        <Style x:Key="ToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                            <!-- Ensure checked state takes precedence over hover -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label Style -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Modern Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="pack://application:,,,/Resources/dha-logo-small.jpg" Width="113" Height="50" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="DHA Time Management" FontSize="20" FontWeight="SemiBold" 
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="SubtitleText" Text="Track time and disbursements efficiently" 
                                 FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="User:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="TeamMemberComboBox" Width="200" Margin="0,0,12,0"
                             DisplayMemberPath="FullName" SelectedValuePath="Id" IsEnabled="False"/>
                    <Button x:Name="DiagnoseQuoteButton" Content="🔍" ToolTip="Diagnose Specific Quote" Width="32" Height="32"
                           Style="{StaticResource SecondaryButtonStyle}" Padding="6" Click="DiagnoseQuoteButton_Click"/>
                    <Button x:Name="DebugQuotesButton" Content="🐛" ToolTip="Debug Quote Loading" Width="32" Height="32"
                           Style="{StaticResource SecondaryButtonStyle}" Padding="6" Click="DebugQuotesButton_Click"/>
                    <Button x:Name="SwitchToDevButton" Content="🧪 DEV" ToolTip="Switch to Dev Environment" Width="Auto" Height="32"
                           Style="{StaticResource SecondaryButtonStyle}" Padding="8,6" Click="SwitchToDevButton_Click"
                           Visibility="Collapsed" FontSize="11" FontWeight="SemiBold"/>
                    <Button x:Name="ImpersonateButton" Content="👤 Impersonate" ToolTip="View the app as another user (admin only)" 
                           Width="Auto" Height="32" Style="{StaticResource SecondaryButtonStyle}" 
                           Padding="8,6" Click="ImpersonateButton_Click"
                           Visibility="Collapsed" FontSize="11" FontWeight="SemiBold"/>
                    <Button x:Name="DebugModeButton" Content="📋 Debug Off" 
                           ToolTip="Toggle debug mode — writes all activity to a log file" 
                           Width="Auto" Height="32" Style="{StaticResource SecondaryButtonStyle}" 
                           Padding="8,6" Click="DebugModeButton_Click"
                           FontSize="11" FontWeight="SemiBold"/>
                    <Button Content="⚙️" ToolTip="Settings" Width="32" Height="32"
                           Style="{StaticResource PrimaryButtonStyle}" Padding="6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Daily Progress Indicator -->
        <!-- Daily Progress Indicator - WebBrowser Version -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" 
        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
        Padding="16,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Daily Progress" 
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" 
                   Margin="0,0,0,8"/>

                <!-- WebBrowser Progress Bar -->
                <WebBrowser x:Name="ProgressWebBrowser" 
                    Grid.Row="1" Height="60"/>
            </Grid>
        </Border>



        <!-- Main Content Tabs -->
        <TabControl x:Name="MainTabControl" Grid.Row="2" Margin="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" Background="Transparent" BorderThickness="0" 
                                       Padding="20,12" Margin="2,0">
                                    <ContentPresenter x:Name="ContentSite"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#E2E8F0"/>
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    </Trigger>
                                    <!-- Fix for active tab hover - keep white text when selected -->
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Time Entry Tab -->
            <TabItem Header="⏱️ Time Entries">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" MinWidth="260" MaxWidth="680"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*" MinWidth="360"/>
                    </Grid.ColumnDefinitions>

                    <!-- Time Entry Form -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-7,0,7,0">
                            <StackPanel>
                                <TextBlock Text="New Time Entry" FontSize="18" FontWeight="SemiBold" 
                                         Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                                <!-- Date section header with Multi-day toggle -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Date" Style="{StaticResource FormLabelStyle}" Margin="0" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="BlockModeCheckBox" Grid.Column="1" Content="Multi-day" FontSize="11"
                                              VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"
                                              Checked="BlockModeCheckBox_Checked" Unchecked="BlockModeCheckBox_Unchecked"/>
                                </Grid>
                                <DatePicker x:Name="TimeEntryDatePicker" Margin="4,0,4,4"/>

                                <!-- Multi-day block entry controls (shown when Multi-day is checked) -->
                                <StackPanel x:Name="BlockModePanel" Visibility="Collapsed" Margin="0,2,0,4">
                                    <TextBlock Text="End Date" Style="{StaticResource FormLabelStyle}"/>
                                    <DatePicker x:Name="BlockEndDatePicker" Margin="4,0,4,4"
                                                SelectedDateChanged="BlockEndDatePicker_SelectedDateChanged"/>
                                    <CheckBox x:Name="SkipWeekendsCheckBox" IsChecked="True" FontSize="11"
                                              Content="Skip weekends (Mon–Fri only)" Margin="4,0,4,6"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              Checked="SkipWeekendsCheckBox_Changed" Unchecked="SkipWeekendsCheckBox_Changed"/>
                                    <Border x:Name="BlockPreviewBorder" Visibility="Collapsed" Background="#EFF6FF"
                                            BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="4"
                                            Padding="8,6" Margin="4,0,4,0">
                                        <TextBlock x:Name="BlockPreviewLabel" FontSize="11" Foreground="#1E40AF" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                                <Border Height="8"/>

                                <!-- Project/Quote Toggle -->
                                <TextBlock Text="Entry Type" Style="{StaticResource FormLabelStyle}"/>
                                <StackPanel Orientation="Horizontal" Margin="4,0,4,12">
                                    <ToggleButton x:Name="ProjectToggle" Content="Project" IsChecked="True" 
                                                Style="{StaticResource ToggleButtonStyle}" Margin="0,0,8,0" Width="80"
                                                Checked="ProjectToggle_Checked"/>
                                    <ToggleButton x:Name="QuoteToggle" Content="Quote" 
                                                Style="{StaticResource ToggleButtonStyle}" Margin="0,0,8,0" Width="80"
                                                Checked="QuoteToggle_Checked"/>
                                </StackPanel>

                                <!-- Project Search and Selection -->
                                <StackPanel x:Name="ProjectSelectionPanel">
                                    <TextBlock Text="Project" Style="{StaticResource FormLabelStyle}"/>
                                    <TextBox x:Name="ProjectSearchBox" Style="{StaticResource ModernTextBoxStyle}"
                                           Margin="4,0,4,4" Text="Search by name, number or client..."/>

                                    <!-- Pinned Projects -->
                                    <StackPanel x:Name="PinnedProjectsSection" Margin="4,0,4,4" Visibility="Collapsed">
                                        <TextBlock Text="📌 Pinned" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#2563EB" Margin="0,0,0,4"/>
                                        <WrapPanel x:Name="PinnedProjectsPanel"/>
                                    </StackPanel>

                                    <!-- Recent Project Searches -->
                                    <StackPanel x:Name="RecentProjectSearchesSection" Margin="4,0,4,6" Visibility="Collapsed">
                                        <TextBlock Text="Recent searches" FontSize="11"
                                                   Foreground="#64748B" Margin="0,0,0,4"/>
                                        <WrapPanel x:Name="RecentProjectSearchesPanel"/>
                                    </StackPanel>

                                    <DataGrid x:Name="ProjectsList" Height="120" Margin="4,0,4,12"
                                             AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                             HeadersVisibility="Column" GridLinesVisibility="Horizontal" IsReadOnly="True"
                                             SelectionMode="Single" SelectedValuePath="Id"
                                             VirtualizingPanel.ScrollUnit="Pixel"
                                             Background="White" BorderThickness="1" BorderBrush="#E2E8F0"
                                             RowHeight="24" FontSize="12">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Project No." Binding="{Binding Number}" Width="80">
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="#2563EB"/>
                                                        <!-- This is the key fix - override foreground when selected -->
                                                        <Style.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Category" Binding="{Binding Discipline}" Width="80">
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="Foreground" Value="#64748B"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Project Name" Binding="{Binding Name}" Width="*">
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="ToolTip" Value="{Binding Name}"/>
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#2563EB"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>
                                    </DataGrid>
                                </StackPanel>
                                <Border x:Name="ProjectClientBorder" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" 
        CornerRadius="4" Padding="8,6" Margin="4,0,4,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Client:" FontSize="11" FontWeight="Medium" 
                      Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="SelectedProjectClientLabel" Text="No project selected" 
                      FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" 
                      FontStyle="Italic" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SelectedProjectDisciplineLabel" Text=""
                      FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                      Margin="0,3,0,0" Visibility="Collapsed"/>
                                        </StackPanel>
                                        <Button x:Name="PinProjectButton" Grid.Column="1"
                                                Content="📌 Pin" Visibility="Collapsed"
                                                VerticalAlignment="Center" Margin="6,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="6,4" FontSize="11"
                                                Click="PinProjectButton_Click"/>
                                    </Grid>
                                </Border>
                                <!-- Quote Search and Selection -->
                                <StackPanel x:Name="QuoteSelectionPanel" Visibility="Collapsed">
                                    <TextBlock Text="Quote" Style="{StaticResource FormLabelStyle}"/>
                                    <TextBox x:Name="QuoteSearchBox" Style="{StaticResource ModernTextBoxStyle}"
                                           Margin="4,0,4,4" Text="Search by name, number or client..."/>

                                    <!-- Pinned Quotes -->
                                    <StackPanel x:Name="PinnedQuotesSection" Margin="4,0,4,4" Visibility="Collapsed">
                                        <TextBlock Text="📌 Pinned" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#2563EB" Margin="0,0,0,4"/>
                                        <WrapPanel x:Name="PinnedQuotesPanel"/>
                                    </StackPanel>

                                    <!-- Recent Quote Searches -->
                                    <StackPanel x:Name="RecentQuoteSearchesSection" Margin="4,0,4,6" Visibility="Collapsed">
                                        <TextBlock Text="Recent searches" FontSize="11"
                                                   Foreground="#64748B" Margin="0,0,0,4"/>
                                        <WrapPanel x:Name="RecentQuoteSearchesPanel"/>
                                    </StackPanel>

                                    <DataGrid x:Name="QuotesList" Height="120" Margin="4,0,4,12"
                                             AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                             HeadersVisibility="Column" GridLinesVisibility="Horizontal" IsReadOnly="True"
                                             SelectionMode="Single" SelectedValuePath="Id"
                                             VirtualizingPanel.ScrollUnit="Pixel"
                                             Background="White" BorderThickness="1" BorderBrush="#E2E8F0"
                                             RowHeight="24" FontSize="12">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Quote No." Binding="{Binding QuoteNumber}" Width="80">
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="#2563EB"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Quote Name" Binding="{Binding Name}" Width="*">
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="ToolTip" Value="{Binding Name}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#2563EB"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>
                                    </DataGrid>
                                    <Border x:Name="QuoteClientBorder" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" 
        CornerRadius="4" Padding="8,6" Margin="4,0,4,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Client:" FontSize="11" FontWeight="Medium" 
                      Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                                <TextBlock x:Name="SelectedQuoteClientLabel" Text="No quote selected" 
                      FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" 
                      FontStyle="Italic" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button x:Name="PinQuoteButton" Grid.Column="1"
                                                    Content="📌 Pin" Visibility="Collapsed"
                                                    VerticalAlignment="Center" Margin="6,0,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="6,4" FontSize="11"
                                                    Click="PinQuoteButton_Click"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="Time Spent" Style="{StaticResource FormLabelStyle}"/>
                                <Grid Margin="4,0,4,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Hours" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="HoursTextBox" Style="{StaticResource ModernTextBoxStyle}"
                                               TextAlignment="Center" MaxLength="2" Margin="0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Bottom" 
                                             Margin="8,0,8,8" FontSize="16" FontWeight="Bold"/>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Minutes" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="MinutesTextBox" Style="{StaticResource ModernTextBoxStyle}"
                                               TextAlignment="Center" MaxLength="2" Margin="0"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Comments *" Style="{StaticResource FormLabelStyle}" Foreground="#DC2626"/>
                                <!-- Comments -->
                                <TextBox x:Name="CommentsTextBox" Style="{StaticResource ModernTextBoxStyle}"
                                       AcceptsReturn="True" TextWrapping="Wrap" Height="80" Margin="4,0,4,16" 
                                       ToolTip="Comments are required for all time entries"/>

                                <!-- Category Selection -->
                                <TextBlock Text="Category" Style="{StaticResource FormLabelStyle}"/>
                                <WrapPanel Orientation="Horizontal" Margin="4,0,4,12">
                                    <RadioButton x:Name="ChargeableRadioButton" Content="Chargeable" 
                 IsChecked="True" Margin="0,0,20,4" GroupName="TimeCategory"/>
                                    <RadioButton x:Name="NonChargeableRadioButton" Content="Non-Chargeable" 
                 Margin="0,0,20,4" GroupName="TimeCategory"/>
                                    <RadioButton x:Name="SpeculativeRadioButton" Content="Speculative" 
                 Margin="0,0,20,4" GroupName="TimeCategory"/>
                                    <RadioButton x:Name="HourlyRateRadioButton" Content="Hourly Rate" 
                 Margin="0,0,20,4" GroupName="TimeCategory"/>
                                </WrapPanel>

                                <Button x:Name="AddTimeEntryButton" Content="Add Time Entry" 
                                      Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch"
                                      Click="AddTimeEntryButton_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Background="#E2E8F0" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

                    <!-- Time Entries List -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="8,8,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header with title and date range -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Recent Time Entries" FontSize="18" FontWeight="SemiBold" 
                                         Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="From:" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <DatePicker x:Name="FromDatePicker" Width="120" Margin="0,0,8,0"/>
                                    <TextBlock Text="To:" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <DatePicker x:Name="ToDatePicker" Width="120"/>
                                    <Button x:Name="RefreshEntriesButton" Content="Refresh" 
                                           Style="{StaticResource SecondaryButtonStyle}" Width="80" Margin="8,0,0,0"/>
                                    <TextBlock x:Name="DateRangeAdjustedLabel"
                                               Text="📅 Date range auto-adjusted"
                                               Visibility="Collapsed"
                                               Foreground="#E67E22"
                                               FontStyle="Italic"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"
                                               ToolTip="The date range was expanded automatically to show your new/edited entry"/>
                                </StackPanel>
                            </Grid>

                            <!-- Summary -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock x:Name="TotalEntriesLabel" Text="Total entries: 0" 
                                         FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                <TextBlock x:Name="TotalHoursLabel" Text="Total: 0m" 
                                         FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Time Entries DataGrid -->
                            <DataGrid x:Name="TimeEntriesDataGrid" Grid.Row="2"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="Transparent" BorderThickness="0"
                                      SelectionMode="Single" IsReadOnly="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      MouseDoubleClick="TimeEntriesDataGrid_MouseDoubleClick"
                                      KeyDown="TimeEntriesDataGrid_KeyDown">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="80"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding ClassificationName}" Width="60"/>
                                    <DataGridTextColumn Header="Project/Quote" Width="*">
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="DisplayName" Mode="OneWay"/>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="120"/>
                                    <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="90"/>
                                    <DataGridTextColumn Header="Time" Binding="{Binding TotalTime}" Width="70"/>
                                    <DataGridTextColumn Header="Comments" Binding="{Binding Comments}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Calendar Tab - Performance Optimised -->
            <!-- Calendar Tab - WebBrowser Version -->
            <TabItem Header="📅 Calendar">
                <Grid Margin="16">
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Calendar Header -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="◀" Width="32" Height="32" 
                            Style="{StaticResource PrimaryButtonStyle}" Padding="6"
                            Click="PreviousMonth_Click"/>

                                <TextBlock Grid.Column="1" x:Name="CalendarTitle" Text="Calendar" 
                               FontSize="20" FontWeight="SemiBold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                                <Button Grid.Column="2" Content="▶" Width="32" Height="32" 
                            Style="{StaticResource PrimaryButtonStyle}" Padding="6"
                            Click="NextMonth_Click"/>
                            </Grid>

                            <WebBrowser x:Name="CalendarWebBrowser" Grid.Row="1" Height="300"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Disbursements Tab -->
            <TabItem Header="💰 Disbursements">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" MinWidth="240" MaxWidth="600"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="320" MinWidth="240" MaxWidth="600"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Project/Quote Search Column -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Search" FontSize="18" FontWeight="SemiBold" 
                                     Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                            <!-- Disbursement Type Toggle -->
                            <TextBlock Text="Disbursement For" Style="{StaticResource FormLabelStyle}"/>
                            <StackPanel Orientation="Horizontal" Margin="4,0,4,12">
                                <ToggleButton x:Name="DisbursementProjectToggle" Content="Project" IsChecked="True" 
                                              Style="{StaticResource ToggleButtonStyle}" Margin="0,0,8,0" Width="80"
                                              Checked="DisbursementProjectToggle_Checked"/>
                                <ToggleButton x:Name="DisbursementQuoteToggle" Content="Quote" 
                                              Style="{StaticResource ToggleButtonStyle}" Margin="0,0,8,0" Width="80"
                                              Checked="DisbursementQuoteToggle_Checked"/>
                            </StackPanel>

                            <!-- Carry-over banner: shown when arriving from the Time Entry panel -->
                            <Border x:Name="CarryOverBanner" Background="#EFF6FF" BorderBrush="#BFDBFE"
                                    BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="4,0,4,8"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="⏱️ Carried from time entry" FontSize="11" FontWeight="Medium"
                                                   Foreground="#1D4ED8" Margin="0,0,0,2"/>
                                        <TextBlock x:Name="CarryOverProjectLabel" Text="" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#1E40AF"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="✕" Width="24" Height="24"
                                            Style="{StaticResource SecondaryButtonStyle}" Padding="2"
                                            FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"
                                            Click="ClearCarryOver_Click"
                                            ToolTip="Clear carry-over and reset selection"/>
                                </Grid>
                            </Border>

                            <!-- Project Selection Panel (existing, enhanced) -->
                            <StackPanel x:Name="DisbursementProjectSelectionPanel">
                                <TextBlock Text="Search Projects" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox x:Name="DisbursementProjectSearchBox" Style="{StaticResource ModernTextBoxStyle}"
                                       Margin="4,0,4,4" Text="Search by name, number or client..."
                                       TextChanged="DisbursementProjectSearchBox_TextChanged"
                                       GotFocus="DisbursementProjectSearchBox_GotFocus"
                                       LostFocus="DisbursementProjectSearchBox_LostFocus"/>

                                <!-- Pinned Projects (disbursements) -->
                                <StackPanel x:Name="DisbPinnedProjectsSection" Margin="4,0,4,4" Visibility="Collapsed">
                                    <TextBlock Text="📌 Pinned" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#2563EB" Margin="0,0,0,4"/>
                                    <WrapPanel x:Name="DisbPinnedProjectsPanel"/>
                                </StackPanel>

                                <!-- Recent Project Searches (disbursements) -->
                                <StackPanel x:Name="DisbRecentProjectSearchesSection" Margin="4,0,4,6" Visibility="Collapsed">
                                    <TextBlock Text="Recent searches" FontSize="11"
                                               Foreground="#64748B" Margin="0,0,0,4"/>
                                    <WrapPanel x:Name="DisbRecentProjectSearchesPanel"/>
                                </StackPanel>

                                <TextBlock Text="Select Project" Style="{StaticResource FormLabelStyle}"/>
                                <DataGrid x:Name="DisbursementProjectsList" Height="300" Margin="4,0,4,12"
                                         AutoGenerateColumns="False" CanUserAddRows="False"
                                         HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                         Background="Transparent" BorderThickness="1"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         SelectionMode="Single" IsReadOnly="True"
                                         ScrollViewer.VerticalScrollBarVisibility="Visible"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         HorizontalGridLinesBrush="#64748B"
                                         VerticalGridLinesBrush="#64748B"
                                         SelectionChanged="DisbursementProjectsList_SelectionChanged">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Number" Binding="{Binding Number}" Width="80" MinWidth="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Medium"/>
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="Padding" Value="6,4"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160" MinWidth="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="6,4"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Client" Binding="{Binding Client}" Width="120" MinWidth="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="6,4"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Category" Binding="{Binding Discipline}" Width="90" MinWidth="70">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="6,4"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>

                                    <!-- Header style to match existing -->
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="6,6"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            <Setter Property="BorderBrush" Value="#64748B"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>

                                    <!-- Row style for consistent selection -->
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="MinHeight" Value="36"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                </MultiTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>

                                    <!-- Cell style to handle selection text color -->
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                </DataGrid>

                                <!-- Selected Project Display -->
                                <Border x:Name="DisbursementProjectClientBorder" Background="#F8FAFC" BorderBrush="#E2E8F0" 
                                        BorderThickness="1" CornerRadius="4" Padding="8" Margin="4,0,4,12" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Client:" FontSize="11" FontWeight="Medium" 
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="SelectedDisbursementProjectClientLabel" Text="No project selected" 
                                                       FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" 
                                                       FontStyle="Italic" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SelectedDisbursementProjectDisciplineLabel" Text=""
                                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,3,0,0" Visibility="Collapsed"/>
                                        </StackPanel>
                                        <Button x:Name="DisbPinProjectButton" Grid.Column="1"
                                                Content="📌 Pin" Visibility="Collapsed"
                                                VerticalAlignment="Center" Margin="6,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="6,4" FontSize="11"
                                                Click="DisbPinProjectButton_Click"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- NEW: Quote Selection Panel -->
                            <StackPanel x:Name="DisbursementQuoteSelectionPanel" Visibility="Collapsed">
                                <TextBlock Text="Search Quotes" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox x:Name="DisbursementQuoteSearchBox" Style="{StaticResource ModernTextBoxStyle}"
                                       Margin="4,0,4,4" Text="Search by name, number or client..."
                                       TextChanged="DisbursementQuoteSearchBox_TextChanged"
                                       GotFocus="DisbursementQuoteSearchBox_GotFocus"
                                       LostFocus="DisbursementQuoteSearchBox_LostFocus"/>

                                <!-- Pinned Quotes (disbursements) -->
                                <StackPanel x:Name="DisbPinnedQuotesSection" Margin="4,0,4,4" Visibility="Collapsed">
                                    <TextBlock Text="📌 Pinned" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#2563EB" Margin="0,0,0,4"/>
                                    <WrapPanel x:Name="DisbPinnedQuotesPanel"/>
                                </StackPanel>

                                <!-- Recent Quote Searches (disbursements) -->
                                <StackPanel x:Name="DisbRecentQuoteSearchesSection" Margin="4,0,4,6" Visibility="Collapsed">
                                    <TextBlock Text="Recent searches" FontSize="11"
                                               Foreground="#64748B" Margin="0,0,0,4"/>
                                    <WrapPanel x:Name="DisbRecentQuoteSearchesPanel"/>
                                </StackPanel>

                                <TextBlock Text="Select Quote" Style="{StaticResource FormLabelStyle}"/>
                                <DataGrid x:Name="DisbursementQuotesList" Height="300" Margin="4,0,4,12"
                                         AutoGenerateColumns="False" CanUserAddRows="False"
                                         HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                         Background="Transparent" BorderThickness="1"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         SelectionMode="Single" IsReadOnly="True"
                                         ScrollViewer.VerticalScrollBarVisibility="Visible"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         HorizontalGridLinesBrush="#64748B"
                                         VerticalGridLinesBrush="#64748B"
                                         SelectionChanged="DisbursementQuotesList_SelectionChanged">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Quote No." Binding="{Binding QuoteNumber}" Width="75">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Medium"/>
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="Padding" Value="6,4"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <!-- THIS IS MISSING -->
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Quote Name" Binding="{Binding Name}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                    <Setter Property="Padding" Value="6,4"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <!-- THIS IS MISSING -->
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Client" Binding="{Binding Client}" Width="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                    <Setter Property="Padding" Value="6,4"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>

                                    <!-- Same styling as project list -->
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="6,6"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            <Setter Property="BorderBrush" Value="#64748B"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="MinHeight" Value="36"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                </MultiTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>

                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                </DataGrid>

                                <!-- Selected Quote Display -->
                                <Border x:Name="DisbursementQuoteClientBorder" Background="#F8FAFC" BorderBrush="#E2E8F0" 
                                        BorderThickness="1" CornerRadius="4" Padding="8" Margin="4,0,4,12" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Client:" FontSize="11" FontWeight="Medium" 
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="SelectedDisbursementQuoteClientLabel" Text="No quote selected" 
                                                       FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" 
                                                       FontStyle="Italic" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button x:Name="DisbPinQuoteButton" Grid.Column="1"
                                                Content="📌 Pin" Visibility="Collapsed"
                                                VerticalAlignment="Center" Margin="6,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="6,4" FontSize="11"
                                                Click="DisbPinQuoteButton_Click"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Button x:Name="ClearProjectSelectionButton" Content="Clear Selection" 
                                  Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" Margin="4,8,4,0"
                                  Click="ClearProjectSelectionButton_Click"/>
                        </StackPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Background="#E2E8F0" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

                    <!-- Disbursement Entry Form (keeping existing structure) -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="New Disbursement" FontSize="18" FontWeight="SemiBold" 
                                         Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                                <TextBlock Text="Date" Style="{StaticResource FormLabelStyle}"/>
                                <DatePicker x:Name="DisbursementDatePicker" Margin="4,0,4,12"/>

                                <TextBlock Text="Project/Quote" Style="{StaticResource FormLabelStyle}"/>
                                <TextBlock x:Name="SelectedProjectLabel" Text="No project or quote selected" 
                                         Margin="4,0,4,12" FontStyle="Italic" 
                                         Foreground="{StaticResource TextSecondaryBrush}"/>

                                <TextBlock Text="Disbursement Type" Style="{StaticResource FormLabelStyle}"/>
                                <ComboBox x:Name="DisbursementTypeComboBox" Margin="4,0,4,12"
                                         DisplayMemberPath="Name" SelectedValuePath="Id"
                                         SelectionChanged="DisbursementTypeComboBox_SelectionChanged"/>

                                <!-- Amount input (shown for non-unit-based disbursements) -->
                                <TextBlock x:Name="AmountLabel" Text="Amount (£)" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox x:Name="DisbursementAmountTextBox" Style="{StaticResource ModernTextBoxStyle}"
                                       Margin="4,0,4,12" TextAlignment="Right"/>

                                <!-- Unit input (shown for unit-based disbursements) -->
                                <TextBlock x:Name="UnitsLabel" Text="Number of Units" Style="{StaticResource FormLabelStyle}" Visibility="Collapsed"/>
                                <StackPanel x:Name="UnitsPanel" Orientation="Horizontal" Margin="4,0,4,12" Visibility="Collapsed">
                                    <TextBox x:Name="DisbursementUnitsTextBox" Style="{StaticResource ModernTextBoxStyle}"
                                             Width="100" TextAlignment="Right" TextChanged="DisbursementUnitsTextBox_TextChanged"/>
                                    <TextBlock x:Name="UnitChargeLabel" Text="× £0.00" VerticalAlignment="Center" 
                                               Margin="8,0,8,0" FontWeight="Medium"/>
                                    <TextBlock x:Name="CalculatedAmountLabel" Text="= £0.00" VerticalAlignment="Center" 
                                               FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>

                                <TextBlock Text="Description" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox x:Name="DisbursementDescriptionTextBox" Style="{StaticResource ModernTextBoxStyle}"
                                       AcceptsReturn="True" TextWrapping="Wrap" Height="80" Margin="4,0,4,16"/>

                                <Button x:Name="AddDisbursementButton" Content="Add Disbursement" 
                                      Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch"
                                      Click="AddDisbursementButton_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Background="#E2E8F0" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

                    <!-- Disbursements List (keeping existing structure) -->
                    <Border Grid.Column="4" Style="{StaticResource CardStyle}" Margin="8,8,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header with title -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" x:Name="DisbursementsHeaderLabel" Text="All Disbursements" FontSize="18" FontWeight="SemiBold" 
                                         Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                                <Button Grid.Column="1" x:Name="RefreshDisbursementsButton" Content="🔄" ToolTip="Refresh" 
                                      Style="{StaticResource PrimaryButtonStyle}" Padding="8,6" Width="32"
                                      Click="RefreshDisbursementsButton_Click"/>
                            </Grid>

                            <!-- Summary row -->
                            <Border Grid.Row="1" Background="#F1F5F9" CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TotalDisbursementsLabel" Text="Total disbursements: 0" 
                                             Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                    <TextBlock x:Name="TotalDisbursementAmountLabel" Text="Total amount: £0.00" 
                                             Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>

                            <DataGrid x:Name="DisbursementsDataGrid" Grid.Row="2" 
                                    AutoGenerateColumns="False" CanUserAddRows="False"
                                    HeadersVisibility="Column" GridLinesVisibility="None"
                                    Background="Transparent" BorderThickness="0"
                                    MouseDoubleClick="DisbursementsDataGrid_MouseDoubleClick"
                                    KeyDown="DisbursementsDataGrid_KeyDown">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="100"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding ClassificationName}" Width="60"/>
                                    <DataGridTextColumn Header="Project/Quote" Width="*">
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="DisplayName" Mode="OneWay"/>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Disbursement Type" Binding="{Binding DisbursementTypeName}" Width="120"/>
                                    <DataGridTextColumn Header="Amount" Width="100">
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="Amount" StringFormat="£{0:F2}"/>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusLabel" Grid.Column="0" Text="Ready v1.0.0" 
           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" x:Name="ConnectionIndicator" Fill="{StaticResource AccentBrush}" 
                           Margin="0,0,8,0"/>
                    <TextBlock x:Name="ConnectionStatusLabel" Text="Connected to Dynamics" 
                             Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
        
        
    </Grid>
</Window>